{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-erb.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
